rder-outline-variant pt-6\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L5\\\",null,{\\\"href\\\":\\\"/cn/posts/ai-coding-cli-tools-comparison/\\\",\\\"className\\\":\\\"text-sm\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"text-on-surface-variant\\\",\\\"children\\\":\\\"上一篇\\\"}],[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"block font-bold\\\",\\\"children\\\":\\\"五大 AI 编程 CLI 工具横评：OpenCode、Claude Code、Codex CLI 怎么选？\\\"}]]}],[\\\"$\\\",\\\"$L5\\\",null,{\\\"href\\\":\\\"/cn/posts/why-tech-docs-fail/\\\",\\\"className\\\":\\\"text-right text-sm\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"text-on-surface-variant\\\",\\\"children\\\":\\\"下一篇\\\"}],[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"block font-bold\\\",\\\"children\\\":\\\"为什么看完技术文档还是不会用？\\\"}]]}]]}]]}],[\\\"$\\\",\\\"$L15\\\",null,{\\\"items\\\":[{\\\"id\\\":\\\"核心原因\\\",\\\"text\\\":\\\"核心原因\\\",\\\"level\\\":2},{\\\"id\\\":\\\"文档是能力的清单不是意图的地图\\\",\\\"text\\\":\\\"文档是能力的清单，不是意图的地图\\\",\\\"level\\\":2},{\\\"id\\\":\\\"文档追求完备和正确回避推荐和取舍\\\",\\\"text\\\":\\\"文档追求完备和正确，回避推荐和取舍\\\",\\\"level\\\":2},{\\\"id\\\":\\\"示例是-hello-world问题是多变量耦合\\\",\\\"text\\\":\\\"示例是 Hello World，问题是多变量耦合\\\",\\\"level\\\":2},{\\\"id\\\":\\\"大量知识是隐性的\\\",\\\"text\\\":\\\"大量知识是隐性的\\\",\\\"level\\\":2},{\\\"id\\\":\\\"更有效的用法\\\",\\\"text\\\":\\\"更有效的用法\\\",\\\"level\\\":2}],\\\"locale\\\":\\\"cn\\\"}]]}]]}]\\n\"])</script><script>self.__next_f.push([1,\":HL[\\\"/images/posts/du-wan-wen-dang-bu-hui-yong/cover.png\\\",\\\"image\\\"]\\n\"])</script><script>self.__next_f.push([1,\"14:[[\\\"$\\\",\\\"img\\\",null,{\\\"src\\\":\\\"/images/posts/du-wan-wen-dang-bu-hui-yong/cover.png\\\",\\\"alt\\\":\\\"开发者面对散落拼图般的技术手册，AI助手如同桥梁将碎片组合成清晰方案的概念插画\\\"}],\\\"\\\\n\\\",[\\\"$\\\",\\\"h2\\\",null,{\\\"children\\\":\\\"核心原因\\\"}],\\\"\\\\n\\\",[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"官方文档是按「有什么」组织的，而你的问题是「我要做什么」——这两种结构几乎永远对不齐。\\\"}],\\\"\\\\n\\\",[\\\"$\\\",\\\"h2\\\",null,{\\\"children\\\":\\\"文档是能力的清单，不是意图的地图\\\"}],\\\"\\\\n\\\",[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":[\\\"文档会告诉你有 hooks、有 subagents、有 skills、有 MCP、有 settings.json 各种字段。但你的问题是「我想让 Claude 每次改完代码自动跑测试」——这需要你先知道答案是 hooks，而文档不会反过来告诉你。\\\",[\\\"$\\\",\\\"strong\\\",null,{\\\"children\\\":\\\"从 feature 到 goal 的映射，是文档最不愿意、也最难写的那部分。\\\"}]]}],\\\"\\\\n\\\",[\\\"$\\\",\\\"h2\\\",null,{\\\"children\\\":\\\"文档追求完备和正确，回避推荐和取舍\\\"}],\\\"\\\\n\\\",[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"真正能解决问题的是「这件事一般大家怎么做、踩过什么坑、什么时候别这么做」，但官方文档为了中立和准确，恰恰会把这些内容删掉。你拿到手的是一份没有观点的说明书，而现实问题永远是在一堆「都可以」里挑一个。\\\"}],\\\"\\\\n\\\",[\\\"$\\\",\\\"h2\\\",null,{\\\"children\\\":\\\"示例是 Hello World，问题是多变量耦合\\\"}],\\\"\\\\n\\\",[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"文档里的示例为了让读者看懂，会刻意简化到只有一个机制在工作。但你实际遇到的是 hooks + subagents + 权限模式 + 工作目录一起出问题，这种组合态文档不可能覆盖。\\\"}],\\\"\\\\n\\\",[\\\"$\\\",\\\"h2\\\",null,{\\\"children\\\":\\\"大量知识是隐性的\\\"}],\\\"\\\\n\\\",[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"很多知识是 tacit 的，只能从「做过」里长出来。比如「这个错误其实是 hook 阻塞了工具，不是模型抽风」——这种判断力是练出来的，文档不会、也没法写成条文。\\\"}],\\\"\\\\n\\\",[\\\"$\\\",\\\"h2\\\",null,{\\\"children\\\":\\\"更有效的用法\\\"}],\\\"\\\\n\\\",[\\\"$\\\",\\\"ul\\\",null,{\\\"children\\\":[\\\"\\\\n\\\",[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"strong\\\",null,{\\\"children\\\":\\\"带着具体问题去搜文档\\\"}],\\\"，而不是通读。把文档当字典，不当教材。\\\"]}],\\\"\\\\n\\\",[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"strong\\\",null,{\\\"children\\\":\\\"直接问已经把 mental model 装进上下文的 LLM\\\"}],\\\"：「我想做 X，该用哪几个能力组合？」它能把「意图 → 机制」的映射补上。\\\"]}],\\\"\\\\n\\\",[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"strong\\\",null,{\\\"children\\\":\\\"看真实配置和 issue\\\"}],\\\"：别人的 \\\",[\\\"$\\\",\\\"code\\\",null,{\\\"className\\\":\\\"rounded bg-surface-variant px-1.5 py-0.5 text-[0.9em]\\\",\\\"children\\\":\\\"settings.json\\\"}],\\\"、GitHub issue 里的真实故障，信息密度远高于文档示例。\\\"]}],\\\"\\\\n\\\",[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"strong\\\",null,{\\\"children\\\":\\\"建最小实验\\\"}],\\\"，跑通了再叠加复杂度。文档是地图，地图不会告诉你「你站在哪、要去哪」。这个 gap 不是读得不够，是文档这种形态天生填不了。\\\"]}],\\\"\\\\n\\\"]}]]\\n\"])</script></body></html>","rsc":"1:\"$Sreact.fragment\"\n2:I[7738,[\"/_next/static/chunks/2offyj585lm1g.js\",\"/_next/static/chunks/14mrh2-p_w84d.js\"],\"ThemeProvider\"]\n3:I[39756,[\"/_next/static/chunks/2offyj585lm1g.js\",\"/_next/static/chunks/14mrh2-p_w84d.js\"],\"default\"]\n4:I[37457,[\"/_next/static/chunks/2offyj585lm1g.js\",\"/_next/static/chunks/14mrh2-p_w84d.js\"],\"default\"]\n5:I[22016,[\"/_next/static/chunks/2offyj585lm1g.js\",\"/_next/static/chunks/14mrh2-p_w84d.js\",\"/_next/static/chunks/0sj6v0vg59-se.js\",\"/_next/static/chunks/3rcqlxwivb0d2.js\"],\"\"]\n8:I[97367,[\"/_next/static/chunks/2offyj585lm1g.js\",\"/_next/static/chunks/14mrh2-p_w84d.js\"],\"OutletBoundary\"]\n9:\"$Sreact.suspense\"\nc:I[97367,[\"/_next/static/chunks/2offyj585lm1g.js\",\"/_next/static/chunks/14mrh2-p_w84d.js\"],\"ViewportBoundary\"]\ne:I[97367,[\"/_next/static/chunks/2offyj585lm1g.js\",\"/_next/static/chunks/14mrh2-p_w84d.js\"],\"MetadataBoundary\"]\n10:I[68027,[\"/_next/static/chunks/2offyj585lm1g.js\",\"/_next/static/chunks/14mrh2-p_w84d.js\"],\"default\",1]\n:HL[\"/_next/static/chunks/3s4_cpi92hjqi.css\",\"style\"]\n0:{\"P\":null,\"c\":[\"\",\"cn\",\"posts\",\"du-wan-wen-dang-bu-hui-yong\",\"\"],\"q\":\"\",\"i\":false,\"f\":[[[\"\",{\"children\":[[\"locale\",\"cn\",\"d\",null],{\"children\":[\"posts\",{\"children\":[[\"slug\",\"du-wan-wen-dang-bu-hui-yong\",\"d\",null],{\"children\":[\"__PAGE__\",{}]}]}]}]},\"$undefined\",\"$undefined\",16],[[\"$\",\"$1\",\"c\",{\"children\":[[[\"$\",\"link\",\"0\",{\"rel\":\"stylesheet\",\"href\":\"/_next/static/chunks/3s4_cpi92hjqi.css\",\"precedence\":\"next\",\"crossOrigin\":\"$undefined\",\"nonce\":\"$undefined\"}],[\"$\",\"script\",\"script-0\",{\"src\":\"/_next/static/chunks/2offyj585lm1g.js\",\"async\":true,\"nonce\":\"$undefined\"}],[\"$\",\"script\",\"script-1\",{\"src\":\"/_next/static/chunks/14mrh2-p_w84