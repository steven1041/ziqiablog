],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"mt-3 flex items-center gap-3 text-sm text-on-surface-variant\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"grid h-9 w-9 place-items-center rounded-full font-bold text-white\\\",\\\"style\\\":{\\\"background\\\":\\\"linear-gradient(135deg, #EA4335, #34A853)\\\"},\\\"children\\\":\\\"Z\\\"}],[\\\"$\\\",\\\"span\\\",null,{\\\"children\\\":[\\\"ZiQia.cc · \\\",\\\"2026-07-13\\\",\\\" · \\\",\\\"3 分钟阅读\\\"]}]]}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"prose prose-neutral max-w-none dark:prose-invert\\\",\\\"children\\\":\\\"$L14\\\"}],[\\\"$\\\",\\\"nav\\\",null,{\\\"className\\\":\\\"mt-12 flex justify-between gap-4 border-t border-outline-variant pt-6\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L5\\\",null,{\\\"href\\\":\\\"/cn/posts/du-wan-wen-dang-bu-hui-yong/\\\",\\\"className\\\":\\\"text-sm\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"text-on-surface-variant\\\",\\\"children\\\":\\\"上一篇\\\"}],[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"block font-bold\\\",\\\"children\\\":\\\"读完技术文档还是不会用？——从「能力清单」到「意图地图」的鸿沟\\\"}]]}],[\\\"$\\\",\\\"span\\\",null,{}]]}]]}],[\\\"$\\\",\\\"$L15\\\",null,{\\\"items\\\":[{\\\"id\\\":\\\"核心原因官方文档是按有什么组织的而你的问题是我要做什么这两种结构几乎永远对不齐\\\",\\\"text\\\":\\\"核心原因：官方文档是按「有什么」组织的，而你的问题是「我要做什么」——这两种结构几乎永远对不齐。\\\",\\\"level\\\":3},{\\\"id\\\":\\\"文档写的是能力的清单不是意图的地图\\\",\\\"text\\\":\\\"文档写的是能力的清单，不是意图的地图。\\\",\\\"level\\\":3},{\\\"id\\\":\\\"文档追求完备和正确回避推荐和取舍\\\",\\\"text\\\":\\\"文档追求完备和正确，回避推荐和取舍。\\\",\\\"level\\\":3},{\\\"id\\\":\\\"更有效的用法\\\",\\\"text\\\":\\\"更有效的用法：\\\",\\\"level\\\":3}],\\\"locale\\\":\\\"cn\\\"}]]}]]}]\\n\"])</script><script>self.__next_f.push([1,\"14:[[\\\"$\\\",\\\"h3\\\",null,{\\\"children\\\":\\\"核心原因：官方文档是按「有什么」组织的，而你的问题是「我要做什么」——这两种结构几乎永远对不齐。\\\"}],\\\"\\\\n\\\",[\\\"$\\\",\\\"h3\\\",null,{\\\"children\\\":\\\"文档写的是能力的清单，不是意图的地图。\\\"}],\\\"\\\\n\\\",[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"文档会告诉你有 hooks、有 subagents、有 skills、有 MCP、有 settings.json 各种字段。但你的问题是「我想让 Claude 每次改完代码自动跑测试」——这需要你先知道答案是 hooks，而文档不会反过来告诉你。从 feature 到 goal 的映射，是文档最不愿意、也最难写的那部分。\\\"}],\\\"\\\\n\\\",[\\\"$\\\",\\\"h3\\\",null,{\\\"children\\\":\\\"文档追求完备和正确，回避推荐和取舍。\\\"}],\\\"\\\\n\\\",[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"真正能解决问题的是「这件事一般大家怎么做、踩过什么坑、什么时候别这么做」，但官方文档为了中立和准确，恰恰会把这些删掉。你拿到的是一份没观点的说明书，而现实问题永远是在一堆「都可以」里挑一个。\\\"}],\\\"\\\\n\\\",[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"例子是 hello-world，问题是多变量耦合。文档里的示例为了让读者看懂，会刻意简化到只有一个机制在工作。但你实际遇到的是 hooks + subagents + 权限模式 + 工作目录一起出问题，这种组合态文档不可能覆盖。\\\"}],\\\"\\\\n\\\",[\\\"$\\\",\\\"p\\\",null,{\\\"children\\\":\\\"很多知识是 tacit 的，只能从「做过」里长出来。比如「这个错误其实是 hook 阻塞了工具，不是模型抽风」——这种判断力是练出来的，文档不会、也没法写成条文。\\\"}],\\\"\\\\n\\\",[\\\"$\\\",\\\"h3\\\",null,{\\\"children\\\":\\\"更有效的用法：\\\"}],\\\"\\\\n\\\",[\\\"$\\\",\\\"ul\\\",null,{\\\"children\\\":[\\\"\\\\n\\\",[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":\\\"带着具体问题去搜文档，而不是通读，当字典不当教材；\\\"}],\\\"\\\\n\\\",[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":\\\"直接问已经把 mental model 装进上下文的 LLM「我想做 X，该用哪几个能力组合」，它能把「意图→机制」的映射补上；\\\"}],\\\"\\\\n\\\",[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":\\\"看真实配置和 issue，别人的 settings.json、GitHub issue 里的真实故障，信息密度远高于文档示例；\\\"}],\\\"\\\\n\\\",[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":\\\"建最小实验，跑通了再叠加复杂度。文档是地图，地图不会告诉你「你站在哪、要去哪」，这个 gap 不是读得不够，是文档这种形态天生填不了。\\\"}],\\\"\\\\n\\\"]}]]\\n\"])</script></body></html>","rsc":"1:\"$Sreact.fragment\"\n2:I[7738,[\"/_next/static/chunks/2offyj585lm1g.js\",\"/_next/static/chunks/14mrh2-p_w84d.js\"],\"ThemeProvider\"]\n3:I[39756,[\"/_next/static/chunks/2offyj585lm1g.js\",\"/_next/static/chunks/14mrh2-p_w84d.js\"],\"default\"]\n4:I[37457,[\"/_next/static/chunks/2offyj585lm1g.js\",\"/_next/static/chunks/14mrh2-p_w84d.js\"],\"default\"]\n5:I[22016,[\"/_next/static/chunks/2offyj585lm1g.js\",\"/_next/static/chunks/14mrh2-p_w84d.js\",\"/_next/static/chunks/0sj6v0vg59-se.js\",\"/_next/static/chunks/3rcqlxwivb0d2.js\"],\"\"]\n8:I[97367,[\"/